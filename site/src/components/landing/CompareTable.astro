---
const yes = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="20 6 9 17 4 12"/></svg>`;
const no = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-5 w-5"><path d="M18 6L6 18M6 6l12 12"/></svg>`;
const rows = [
  { name: 'Auto VM provision',                       a: yes, b: yes, c: yes },
  { name: 'Multiple tunnels per VM',                 a: no,  b: yes, c: yes },
  { name: 'Bin-packing scheduler',                   a: no,  b: no,  c: yes },
  { name: 'Cheapest-fit instance type',              a: no,  b: no,  c: yes },
  { name: 'Pool budget caps',                        a: no,  b: no,  c: yes },
  { name: 'Drift detection + auto consolidation',    a: no,  b: no,  c: yes },
];
---
<section class="border-y border-[var(--line)] bg-[var(--bg-elev-2)] px-6 py-24 mt-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-3 text-center text-xs font-bold uppercase tracking-[0.08em] text-accent">Compare</div>
    <h2 class="text-center font-heading text-3xl font-semibold tracking-tight md:text-4xl">Pick the right operator.</h2>
    <p class="mx-auto mb-14 mt-3 max-w-[60ch] text-center text-base text-ink-muted md:text-lg">
      Same neighborhood, different priorities. Here's how the three stack up.
    </p>
    <div class="overflow-x-auto rounded-lg border border-[var(--line)] bg-white shadow-md">
      <div class="min-w-[540px]">
        <div class="grid grid-cols-[1.4fr_1fr_1fr_1fr] items-center bg-[var(--bg-elev-2)] px-5 py-4 text-sm md:grid-cols-[1.6fr_1fr_1fr_1fr]">
          <span></span>
          <span class="text-center font-heading font-bold">inlets-operator</span>
          <span class="text-center font-heading font-bold">chisel-operator</span>
          <span class="text-center font-heading font-bold text-accent">
            frp-operator
            <span class="ml-1 inline-block rounded-full bg-accent px-1.5 py-0.5 align-middle text-[10px] font-bold text-white">ours</span>
          </span>
        </div>
        {rows.map((r) => (
          <div class="grid grid-cols-[1.4fr_1fr_1fr_1fr] items-center border-t border-[var(--line)] px-5 py-3 text-sm md:grid-cols-[1.6fr_1fr_1fr_1fr]">
            <span class="text-left font-medium text-ink">{r.name}</span>
            <span class={`flex items-center justify-center ${r.a === yes ? 'text-accent' : 'text-slate-400'}`} set:html={r.a}></span>
            <span class={`flex items-center justify-center ${r.b === yes ? 'text-accent' : 'text-slate-400'}`} set:html={r.b}></span>
            <span class={`flex items-center justify-center ${r.c === yes ? 'text-accent' : 'text-slate-400'}`} set:html={r.c}></span>
          </div>
        ))}
        <div class="grid grid-cols-[1.4fr_1fr_1fr_1fr] items-center border-t border-[var(--line)] px-5 py-3 text-sm md:grid-cols-[1.6fr_1fr_1fr_1fr]">
          <span class="text-left font-medium text-ink">Tunnel protocol</span>
          <span class="text-center text-xs text-ink-muted">inlets</span>
          <span class="text-center text-xs text-ink-muted">chisel</span>
          <span class="text-center text-xs font-semibold text-accent">frp (TCP/UDP/HTTP/HTTPS)</span>
        </div>
        <div class="border-t border-[var(--line)] bg-[var(--bg-elev-2)] px-5 py-4 text-xs text-ink-faint">
          Last verified against inlets-operator v0.18 and chisel-operator main · 2026-05-06.
        </div>
      </div>
    </div>
  </div>
</section>
