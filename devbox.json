{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
  "packages": [
    "gnumake@latest",
    "wireguard-tools@latest",
    "bc@latest",
    "python@latest",
    "jq@latest",
    "glow@latest",
    "go@1.24",
    "kubebuilder@latest",
    "kustomize@latest",
    "k3d@latest",
    "kubectl@latest"
  ],
  "env": {
    "GOPATH": "$HOME/go/",
    "PATH":   "$PATH:$HOME/go/bin"
  },
  "shell": {
    "init_hook": [
      "export \"GOROOT=$(go env GOROOT)\""
    ],
    "scripts": {
      "test": [
        "go test ./..."
      ]
    }
  }
}
